NEBIUS_API_KEY=XXX
HF_TOKEN=
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=coding-agent-evals
PIPELINE_DOCKER_IMAGE=mlops-assignment-e2e-ml-pipeline:local
HOST_PROJECT_ROOT=/absolute/path/to/mlops-assignment-e2e-ml-pipeline

# Optional Nebius Object Storage upload for completed runs.
# Nebius Object Storage is S3-compatible, so AWS-style credentials and the AWS CLI
# can be used as the client interface. This does not require using AWS cloud.
# Use a Nebius Object Storage static access key and your Nebius bucket name below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north1
# Endpoint for the Nebius region that contains the bucket.
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
S3_BUCKET=
S3_PREFIX=mlops-assignment-runs
